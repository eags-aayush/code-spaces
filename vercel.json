{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        },
        "middleware": [
            {
                "name": "rewrite-urls",
                "options": {
                    "source": "/_next",
                    "destination": "/"
                }
            }
        ]
    }
}